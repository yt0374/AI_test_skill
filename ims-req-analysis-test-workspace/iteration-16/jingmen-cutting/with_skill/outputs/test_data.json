{
  "cpo_profiles": {
    "description": "CPO data profiles for cutting task creation and ticket printing",
    "dataset": [
      {"id": "D01-1", "cpo_code": "CPO1", "quantity": 500, "delivery_date": "2026-07-01", "type": "single", "expected_ticket": "specific"},
      {"id": "D01-2", "cpo_code": "CPO2", "quantity": 300, "delivery_date": "2026-07-05", "type": "single", "expected_ticket": "specific"},
      {"id": "D01-3", "cpo_code": "CPO3", "quantity": 200, "delivery_date": "2026-07-02", "type": "single", "expected_ticket": "specific"},
      {"id": "D01-4", "cpo_codes": ["CPO4", "CPO5"], "quantity": [800, 200], "delivery_date": "2026-07-03", "type": "merged_same_date", "expected_ticket": "generic"},
      {"id": "D01-5", "cpo_codes": ["CPO6", "CPO7"], "quantity": [400, 600], "delivery_date": ["2026-07-01", "2026-07-04"], "type": "merged_diff_date", "expected_ticket": "generic"},
      {"id": "D01-6", "cpo_code": "CPO-FULL", "quantity": 0, "delivery_date": "2026-07-10", "type": "full", "expected_behavior": "skip_or_block"}
    ]
  },
  "marker_allocation": {
    "description": "Marker layer allocation scenarios",
    "test_id": "C-06, V-01~V-06",
    "dataset": [
      {"id": "D02-1", "total_layers": 100, "allocated": 0, "available": 100, "try_allocate": 40, "expected": "pass", "remaining": 60},
      {"id": "D02-2", "total_layers": 100, "allocated": 40, "available": 60, "try_allocate": 50, "expected": "pass", "remaining": 10},
      {"id": "D02-3", "total_layers": 100, "allocated": 90, "available": 10, "try_allocate": 10, "expected": "pass", "remaining": 0},
      {"id": "D02-4", "total_layers": 100, "allocated": 100, "available": 0, "try_allocate": 1, "expected": "block", "message": "无可用层数"},
      {"id": "D02-5", "total_layers": 100, "allocated": 90, "available": 10, "try_allocate": 11, "expected": "block", "message": "超过可用层数"},
      {"id": "D02-6", "total_layers": 100, "allocated": 0, "available": 100, "try_allocate": 0, "expected": "block", "message": "层数必须大于0"},
      {"id": "D02-7", "total_layers": 100, "allocated": 0, "available": 100, "try_allocate": -5, "expected": "block", "message": "无效输入"}
    ]
  },
  "bed_layer_validation": {
    "description": "Bed number layer input validation",
    "test_id": "C-09, V-07~V-14",
    "dataset": [
      {"id": "D03-1", "remaining": 50, "input_layers": 20, "expected": "pass", "new_remaining": 30, "warning": false},
      {"id": "D03-2", "remaining": 50, "input_layers": 50, "expected": "pass", "new_remaining": 0, "warning": false},
      {"id": "D03-3", "remaining": 50, "input_layers": 41, "expected": "pass", "new_remaining": 9, "warning": true},
      {"id": "D03-4", "remaining": 50, "input_layers": 40, "expected": "pass", "new_remaining": 10, "warning": false},
      {"id": "D03-5", "remaining": 50, "input_layers": 51, "expected": "block", "new_remaining": 50, "warning": false, "message": "总裁剪层数已超计划"},
      {"id": "D03-6", "remaining": 50, "input_layers": 60, "expected": "block", "new_remaining": 50, "warning": false, "message": "总裁剪层数已超计划"},
      {"id": "D03-7", "remaining": 50, "input_layers": 0, "expected": "block", "new_remaining": 50, "message": "无效输入"},
      {"id": "D03-8", "remaining": 50, "input_layers": -5, "expected": "block", "new_remaining": 50, "message": "无效输入"}
    ]
  },
  "bed_submit_validation": {
    "description": "Bed submission actual layer validation",
    "test_id": "C-10, V-12~V-14",
    "dataset": [
      {"id": "D04-1", "reserved": 20, "remaining": 30, "actual": 20, "expected": "pass", "locked": 20, "released": 0},
      {"id": "D04-2", "reserved": 20, "remaining": 30, "actual": 18, "expected": "pass", "locked": 18, "released": 2},
      {"id": "D04-3", "reserved": 20, "remaining": 10, "actual": 25, "expected": "pass", "locked": 25, "released": 0},
      {"id": "D04-4", "reserved": 20, "remaining": 5, "actual": 30, "expected": "block", "locked": 0, "message": "实际层数超出可调整范围"}
    ]
  },
  "auto_fill_order": {
    "description": "Auto fill CPO priority order for hanging",
    "test_id": "F-07, F-08",
    "dataset": [
      {"id": "D05-1", "cpos": [{"code": "CPO1", "qty": 500, "date": "2026-07-01"}, {"code": "CPO3", "qty": 200, "date": "2026-07-02"}, {"code": "CPO2", "qty": 300, "date": "2026-07-05"}], "expected_order": ["CPO1", "CPO3", "CPO2"]},
      {"id": "D05-2", "cpos": [{"code": "CPO2", "qty": 300, "date": "2026-07-05"}, {"code": "CPO1", "qty": 500, "date": "2026-07-01"}], "expected_order": ["CPO1", "CPO2"]},
      {"id": "D05-3", "cpos": [{"code": "CPO4", "qty": 0, "date": "2026-07-03"}, {"code": "CPO5", "qty": 200, "date": "2026-07-04"}], "expected_order": ["CPO5"]}
    ]
  }
}
